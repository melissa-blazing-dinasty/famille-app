rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Accès autorisé à toute personne connectée (même anonymement),
    // à condition de connaître le "familyCode" utilisé comme chemin.
    // Le code fait donc office de clé d'accès : choisis-en un long
    // et pas facile à deviner, et ne le partage qu'en famille.
    match /familles/{familyCode}/store/{key} {
      allow read, write: if request.auth != null;
    }
  }
}
